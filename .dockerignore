# Ignore Docker files
Dockerfile
docker-compose.yml
.dockerignore

# Ignore system files
.DS_Store
Thumbs.db

# Ignore Maven wrapper files (since build image provides its own Maven)
.mvn/
mvnw
mvnw.cmd

# Ignore documentation files
HELP.md
